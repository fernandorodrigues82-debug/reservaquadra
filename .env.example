# Copie este arquivo para ".env" e preencha com seus dados reais.
# NUNCA suba o arquivo ".env" para o GitHub (ele já está no .gitignore).

TOWNSQ_EMAIL=seu_email@exemplo.com
TOWNSQ_SENHA=sua_senha_aqui
TOWNSQ_LOGIN_URL=https://app.townsq.com.br/login

# Roda o navegador sem interface gráfica (True em produção/servidor)
HEADLESS=True
